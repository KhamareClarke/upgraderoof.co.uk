# ── Tracking & Analytics ──────────────────────────────
# Google Tag Manager
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXXX

# Google Analytics 4
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Ads
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXXX

# Google Ads conversion label (format: AW-XXXXX/YYYYY)
# Used as the 'send_to' value for conversion events
NEXT_PUBLIC_GA_CONVERSION_SEND_TO=AW-XXXXXXXXXX/YYYYYYYYY

# Meta (Facebook) Pixel
NEXT_PUBLIC_FB_PIXEL_ID=XXXXXXXXXXXXXXX

# ── Supabase (Database) ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Email (contact forms via Gmail SMTP + Nodemailer) ──
# Use a Gmail App Password (Google Account → Security → 2-Step Verification → App passwords).
# Do not use your normal Gmail password.
SMTP_USER=your.address@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM=your.address@gmail.com
EMAIL_TO=upgraderoofs@yahoo.com

# Optional: if you switch the API routes to Resend instead of Nodemailer
# RESEND_API_KEY=re_XXXXXXXXXX

# ── Optional: Google Maps ────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
